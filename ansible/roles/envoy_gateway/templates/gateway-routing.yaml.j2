---
apiVersion: gateway.networking.k8s.io/v1
kind: GatewayClass
metadata:
  name: {{ envoy_gateway_class_name }}
spec:
  controllerName: {{ envoy_gateway_controller_name }}
---
apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: {{ envoy_gateway_name }}
  namespace: {{ envoy_gateway_namespace }}
spec:
  gatewayClassName: {{ envoy_gateway_class_name }}
  listeners:
    - name: http
      protocol: HTTP
      port: {{ envoy_gateway_http_port }}
      allowedRoutes:
        namespaces:
          from: All
{% if envoy_gateway_argocd_route_enabled | bool %}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ envoy_gateway_argocd_service_name }}
  namespace: {{ argocd_namespace }}
  labels:
    app.kubernetes.io/name: argocd-gui
    app.kubernetes.io/part-of: argocd
    kyverno-mvp.local/gui: "true"
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: argocd-server
  ports:
    - name: http
      port: {{ envoy_gateway_argocd_service_port }}
      protocol: TCP
      targetPort: 8080
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{ envoy_gateway_argocd_route_name }}
  namespace: {{ argocd_namespace }}
spec:
  parentRefs:
    - name: {{ envoy_gateway_name }}
      namespace: {{ envoy_gateway_namespace }}
  hostnames:
    - {{ envoy_gateway_argocd_hostname }}
  rules:
    - backendRefs:
        - name: {{ envoy_gateway_argocd_service_name }}
          port: {{ envoy_gateway_argocd_service_port }}
{% endif %}
